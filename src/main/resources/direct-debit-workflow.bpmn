    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_14n1k4o" sourceRef="duplicate_check_task" targetRef="Gateway_0skt594" />
    <bpmn:serviceTask id="debulking_request_task" name="Send file for Debulking" camunda:class="com.forward.direct.debit.camunda.task.executor.CamundaTaskExecutor">
      <bpmn:incoming>Flow_1jb3ets</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1jb3ets" name="File is not duplicate" sourceRef="Gateway_0skt594" targetRef="debulking_request_task">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!is_file_duplicate}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0485r33" name="Duplicate file" sourceRef="Gateway_0skt594" targetRef="EndEvent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${is_file_duplicate}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
