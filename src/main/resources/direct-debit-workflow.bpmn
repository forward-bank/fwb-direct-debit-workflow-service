          <dc:Bounds x="543" y="275" width="55" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="customer_validation_task_di" bpmnElement="customer_validation_task">
