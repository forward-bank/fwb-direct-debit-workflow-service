    <bpmn:sequenceFlow id="Flow_03gdka7" name="Valid Customer" sourceRef="Gateway_0f33xtl" targetRef="Gateway_17k6s5t">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${is_customer_valid}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_17k6s5t">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_03gdka7</bpmn:incoming>
      <bpmn:outgoing>Flow_0qjyaz7</bpmn:outgoing>
      <bpmn:outgoing>Flow_1jdd9q0</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0qjyaz7" name="File is not encrypted" sourceRef="Gateway_17k6s5t" targetRef="syntax_validation_request_task">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!is_file_encrypted}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0g7s4k9" name="Invalid Customer" sourceRef="Gateway_0f33xtl" targetRef="Event_02rksz2">
