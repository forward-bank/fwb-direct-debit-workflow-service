      <bpmn:outgoing>Flow_09ol1fk</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_09ol1fk" sourceRef="syntax_validation_request_task" targetRef="syntax_validation_response_task" />
    <bpmn:receiveTask id="syntax_validation_response_task" name="Receive response from Syntax Validation Service" messageRef="Message_2kvsq39">
      <bpmn:incoming>Flow_09ol1fk</bpmn:incoming>
      <bpmn:outgoing>Flow_1xxmt9b</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:sequenceFlow id="Flow_1xxmt9b" sourceRef="syntax_validation_response_task" targetRef="syntax_validation_evaluation" />
    <bpmn:sequenceFlow id="Flow_1jdd9q0" name="File is encrypted" sourceRef="Gateway_17k6s5t" targetRef="EndEvent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${is_file_encrypted}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="syntax_validation_evaluation">
      <bpmn:incoming>Flow_1xxmt9b</bpmn:incoming>
      <bpmn:outgoing>Flow_1f8r93k</bpmn:outgoing>
      <bpmn:outgoing>Flow_0qyiaeq</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="duplicate_check_task" name="Check for duplicate" camunda:class="com.forward.direct.debit.camunda.task.executor.CamundaTaskExecutor">
      <bpmn:incoming>Flow_1f8r93k</bpmn:incoming>
      <bpmn:outgoing>Flow_14n1k4o</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1f8r93k" name="Valid Syntax" sourceRef="syntax_validation_evaluation" targetRef="duplicate_check_task">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${is_syntax_valid}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0qyiaeq" name="Invalid Syntax" sourceRef="syntax_validation_evaluation" targetRef="EndEvent">
